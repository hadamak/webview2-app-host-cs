{
  "title": "WebView2 ホストテスト",
  "width": 900,
  "height": 640,
  "fullscreen": false,
  "proxyOrigins": [
    "https://httpbin.org",
    "https://jsonplaceholder.typicode.com"
  ],
  "loadDlls": [
    {
      "alias": "Steam",
      "dll": "Facepunch.Steamworks.Win64.dll",
      "exposeEvents": ["OnAchievementProgress", "OnGameOverlayActivated", "OnMicroTxnAuthorizationResponse"]
    }
  ],
  "sidecars": [
    {
      "alias": "Node",
      "mode": "streaming",
      "executable": "node",
      "workingDirectory": "node-runtime",
      "args": ["server.js"],
      "waitForReady": true
    },
    {
      "alias": "Ping",
      "mode": "cli",
      "executable": "ping",
      "args": ["-n", "1", "{args}"],
      "waitForReady": false,
      "encoding": "sjis"
    }
  ]
}
