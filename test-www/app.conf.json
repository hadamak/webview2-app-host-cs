{
  "title": "WebView2 ホストテスト",
  "window": {
    "width": 1280,
    "height": 960,
    "fullscreen": false,
    "frame": true
  },
  "url": "https://app.local/index.html",
  "proxy_origins": [
    "https://httpbin.org",
    "https://jsonplaceholder.typicode.com"
  ],
  "navigation_policy": {
    "external_navigation_mode": "browser",
    "block_request_patterns": []
  },
  "connectors": [
    {
      "type": "browser",
      "alias": "Browser"
    },
    {
      "type": "dll",
      "alias": "Steam",
      "path": "Facepunch.Steamworks.Win64.dll",
      "expose_events": [
        "OnAchievementProgress",
        "OnGameOverlayActivated",
        "OnMicroTxnAuthorizationResponse"
      ]
    },
    {
      "type": "sidecar",
      "alias": "PythonRuntime",
      "mode": "streaming",
      "executable": "python",
      "working_directory": "../../../../../",
      "args": ["-u", "src/bin/x64/Debug/net48/python-runtime/server.py"],
      "wait_for_ready": true
    }
  ]
}
