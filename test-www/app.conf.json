{
  "title": "WebView2 ホストテスト",
  "width": 900,
  "height": 640,
  "fullscreen": false,
  "proxyOrigins": [
    "https://httpbin.org",
    "https://jsonplaceholder.typicode.com"
  ],
  "loadDlls": [
    {
      "alias": "Steam",
      "dll": "Facepunch.Steamworks.Win64.dll",
      "exposeEvents": ["OnAchievementProgress", "OnGameOverlayActivated", "OnMicroTxnAuthorizationResponse"]
    }
  ],
  "sidecars": [
    {
      "alias": "PythonRuntime",
      "mode": "streaming",
      "executable": "python",
      "workingDirectory": "../../../../../",
      "args": ["-u", "src/bin/x64/Debug/net48/python-runtime/server.py"],
      "waitForReady": true,
      "encoding": "sjis"
    }
  ]
}
