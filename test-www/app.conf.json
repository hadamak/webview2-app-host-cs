{
  "title": "WebView2 ホストテスト",
  "width": 900,
  "height": 640,
  "fullscreen": false,
  "proxyOrigins": [
    "https://httpbin.org",
    "https://jsonplaceholder.typicode.com"
  ],
  "loadDlls": [
    {
      "alias": "Steam",
      "dll": "Facepunch.Steamworks.Win64.dll",
      "exposeEvents": ["OnAchievementProgress", "OnGameOverlayActivated", "OnMicroTxnAuthorizationResponse"]
    }
  ],
  "sidecars": [
    {
      "alias": "Node",
      "mode": "streaming",
      "executable": "node",
      "args": ["C:/Users/btqwm/Documents/webview2-app-host-cs/samples/sidecar/node-runtime/server.js"],
      "workingDirectory": "C:/Users/btqwm/Documents/webview2-app-host-cs",
      "waitForReady": true
    },
    {
      "alias": "PythonRuntime",
      "mode": "streaming",
      "executable": "python",
      "args": ["-u", "C:/Users/btqwm/Documents/webview2-app-host-cs/samples/sidecar/python-runtime/server.py"],
      "workingDirectory": "C:/Users/btqwm/Documents/webview2-app-host-cs",
      "waitForReady": true
    },
    {
      "alias": "PowershellRuntime",
      "mode": "streaming",
      "executable": "powershell",
      "args": ["-ExecutionPolicy", "Bypass", "-File", "C:/Users/btqwm/Documents/webview2-app-host-cs/samples/sidecar/powershell-runtime/server.ps1"],
      "workingDirectory": "C:/Users/btqwm/Documents/webview2-app-host-cs",
      "waitForReady": true
    },
    {
      "alias": "Ping",
      "mode": "cli",
      "executable": "ping",
      "args": ["-n", "1", "{args}"],
      "waitForReady": false,
      "encoding": "sjis"
    },
    {
      "alias": "Agent",
      "mode": "streaming",
      "executable": "node",
      "args": ["C:/Users/btqwm/Documents/webview2-app-host-cs/samples/sidecar/node-agent/agent.js"],
      "workingDirectory": "C:/Users/btqwm/Documents/webview2-app-host-cs",
      "waitForReady": true
    }
  ]
}
