{
  "title": "Sidecar Node Sample",
  "window": { "width": 1280, "height": 800, "frame": true },
  "url": "https://app.local/index.html",
  "navigation_policy": {
    "allow_external_hosts": [],
    "block_request_patterns": []
  },
  "sub_streams": {
    "enabled": true,
    "max_concurrent_streams": 3
  },
  "connectors": [
    {
      "type": "sidecar",
      "alias": "Node",
      "runtime": "node",
      "script": "node-runtime/server.js",
      "working_directory": "node-runtime",
      "wait_for_ready": true
    }
  ]
}
