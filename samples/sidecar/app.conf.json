{
  "title": "Legacy Sidecar Sample",
  "window": { "width": 1280, "height": 800, "frame": true },
  "url": "https://app.local/index.html",
  "connectors": [
    {
      "type": "sidecar",
      "alias": "PowerShell",
      "mode": "streaming",
      "executable": "powershell",
      "working_directory": "powershell-runtime",
      "args": ["server.ps1"],
      "wait_for_ready": true
    },
    {
      "type": "sidecar",
      "alias": "Ping",
      "mode": "cli",
      "executable": "ping",
      "args": ["-n", "1", "{args}"],
      "wait_for_ready": false,
      "encoding": "sjis"
    }
  ]
}
