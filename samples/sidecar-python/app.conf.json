{
  "title": "Sidecar Python Sample",
  "window": { "width": 1280, "height": 800, "frame": true },
  "url": "https://app.local/index.html",
  "navigation_policy": {
    "allow_external_hosts": [],
    "block_request_patterns": []
  },
  "sub_streams": {
    "enabled": true,
    "max_concurrent_streams": 3
  },
  "connectors": [
    {
      "type": "sidecar",
      "alias": "Python",
      "runtime": "python",
      "script": "python-runtime/server.py",
      "working_directory": "python-runtime",
      "wait_for_ready": true
    }
  ]
}
