{
  "title": "Steam Complete Sample",
  "window": {
    "width": 1280,
    "height": 800,
    "frame": true
  },
  "url": "https://app.local/index.html",
  "navigation_policy": {
    "external_navigation_mode": "browser",
    "block_request_patterns": []
  },
  "sub_streams": {
    "enabled": true,
    "max_concurrent_streams": 4
  },
  "steam": {
    "app_id": "480",
    "dev_mode": true
  },
  "connectors": [
    {
      "type": "dll",
      "alias": "Steam",
      "path": "Facepunch.Steamworks.Win64.dll",
      "expose_events": [
        "OnAchievementProgress",
        "OnGameOverlayActivated",
        "OnMicroTxnAuthorizationResponse",
        "OnScreenshotReady"
      ]
    }
  ]
}
